OPENAI_API_KEY=sk-...
# Optional: defaults to gpt-4o-mini (policy-extract/summarizer.ts)
# OPENAI_MODEL=gpt-4o-mini

TINYFISH_API_KEY=sk-tinyfish-...
# Optional override; default is https://agent.tinyfish.ai (see TinyFish docs)
# TINYFISH_BASE_URL=https://agent.tinyfish.ai

# policy-extract: per-source HTTP timeout (ms) for sync /v1/automation/run (default 300000)
# TINYFISH_FETCH_TIMEOUT_MS=300000
# Which sources fetchWebData uses (comma-separated). Run: npm run benchmark:sources
# Valid ids: cna, reddit, reddit_search, hwz — default if unset: cna,reddit_search
# TINYFISH_SOURCES=cna,reddit_search
# Offline dev only: fall back to mock web text / mock PolicyContext when APIs fail or keys missing
# POLICY_EXTRACT_ALLOW_MOCK=0
