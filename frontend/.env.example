# Production / preview: point the SPA at your Railway (or other) API.
# Build-time only — set in Vercel/Netlify/Railway static host env, or:
#   VITE_API_URL=https://your-app.up.railway.app npm run build
VITE_API_URL=

# Optional: if WebSocket host differs from HTTP (usually leave unset; ws/wss is derived from VITE_API_URL)
# VITE_WS_URL=
